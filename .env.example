# Copy to .env (gitignored) and fill real values for the LOCAL DEV LOOP only.
# Canonical run credentials live in Databricks secret scopes (journey/09_SECURITY_AND_ACCESS.md
# §1), never in this file with real values. This file is allowlisted in
# gates/framework.yml -> secrets_scan.allowlist_paths precisely because every value below is a
# placeholder, not a real secret.

# --- Postgres ("Sales / Loan Dept") ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=banking_sales
POSTGRES_USER=banking_dev
POSTGRES_PASSWORD=changeme

# --- MS SQL Server ("Credit Card + Fraud") ---
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DB=banking_cards
MSSQL_USER=sa
MSSQL_PASSWORD=changeme

# --- SAP HANA Cloud (BTP Free Tier, "Internal CRM" — ADR-006, replaces the old file-drop sim) ---
SAP_HANA_HOST=changeme
SAP_HANA_PORT=443
SAP_HANA_USER=changeme
SAP_HANA_PASSWORD=changeme

# --- Teradata ("Marketing / Campaign" — ADR-006, new source) ---
TERADATA_HOST=changeme
TERADATA_USER=changeme
TERADATA_PASSWORD=changeme

# --- Open Bank Project sandbox ---
OBP_BASE_URL=https://apisandbox.openbankproject.com
OBP_CONSUMER_KEY=changeme
OBP_CONSUMER_SECRET=changeme
OBP_USERNAME=changeme
OBP_PASSWORD=changeme

# --- Kaggle API (seed-time dataset download only) ---
KAGGLE_USERNAME=changeme
KAGGLE_KEY=changeme

# --- Storage (dev loop) ---
# Leave AWS_* unset to use the local-disk fallback under ./data/ (same layout as S3).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=changeme
S3_PREFIX=banking/

# --- Databricks (canonical run only) ---
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# --- Snowflake (Fasa E serving, optional) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# --- Alerting (journey/07_PIPELINE_SPEC.md "Failure handling") ---
SLACK_WEBHOOK_URL=

# --- Fasa B: which layer to control-plane-drive ---
USE_UNITY_CATALOG=false
